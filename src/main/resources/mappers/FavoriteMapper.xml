<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mapple.dao.FavoriteDao">

    <resultMap id="favoriteMap" type="FavoriteDto">
        <id     property="favId"    column="fav_id"/>
        <result property="memberId" column="member_id"/>
        <result property="charName" column="char_name"/>
        <result property="regDate"  column="reg_date"/>
    </resultMap>

    <insert id="insert" parameterType="FavoriteDto">
        INSERT INTO favorite_tb (fav_id, member_id, char_name)
        VALUES (favorite_seq.NEXTVAL, #{memberId}, #{charName})
    </insert>

    <select id="findByMemberId" parameterType="int" resultMap="favoriteMap">
        SELECT * FROM favorite_tb WHERE member_id = #{memberId} ORDER BY reg_date DESC
    </select>

    <delete id="delete" parameterType="int">
        DELETE FROM favorite_tb WHERE fav_id = #{favId}
    </delete>

    <select id="countByMemberAndChar" parameterType="FavoriteDto" resultType="int">
        SELECT COUNT(*) FROM favorite_tb
        WHERE member_id = #{memberId} AND char_name = #{charName}
    </select>

</mapper>
