<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mapple.dao.CommentDao">

    <resultMap id="commentMap" type="CommentDto">
        <id     property="commentId"  column="comment_id"/>
        <result property="boardId"    column="board_id"/>
        <result property="memberId"   column="member_id"/>
        <result property="content"    column="content"/>
        <result property="regDate"    column="reg_date"/>
        <result property="writerName" column="name"/>
        <result property="loginId"    column="login_id"/>
    </resultMap>

    <insert id="insert" parameterType="CommentDto">
        INSERT INTO comment_tb (comment_id, board_id, member_id, content)
        VALUES (comment_seq.NEXTVAL, #{boardId}, #{memberId}, #{content})
    </insert>

    <select id="findByBoardId" parameterType="int" resultMap="commentMap">
        SELECT c.*, m.name, m.login_id
        FROM comment_tb c
        JOIN member_tb m ON c.member_id = m.member_id
        WHERE c.board_id = #{boardId}
        ORDER BY c.comment_id
    </select>

    <delete id="delete" parameterType="int">
        DELETE FROM comment_tb WHERE comment_id = #{commentId}
    </delete>

</mapper>
